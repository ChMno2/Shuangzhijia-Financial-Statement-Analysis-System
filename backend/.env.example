# Google Sheets 設定
GOOGLE_CREDENTIALS_FILE=credentials.json
# 雲端部署時改用此變數（填入 credentials.json 的完整 JSON 字串）
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
SPREADSHEET_ID=你的_Google_試算表_ID

# Anthropic Claude API Key
# 取得：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Tavily Search API（用於網路搜尋 + 日本潮流查詢）
# 免費 1,000 次/月：https://app.tavily.com
TAVILY_API_KEY=tvly-dev-...

# 伺服器設定
PORT=8000
CORS_ORIGINS=http://localhost:5173

# 登入帳號設定（執行 python3 gen_password.py 產生密碼 hash）
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# JWT 設定（勿外洩，可用任意隨機字串）
JWT_SECRET_KEY=請換成隨機字串
JWT_EXPIRE_HOURS=12
